# AI Native Compass - Environment Configuration
# Copy this file to .env and update the values before running the application.

# Database
DB_PASSWORD=change_me_to_a_secure_password

# Flask
FLASK_SECRET_KEY=change_me_to_a_random_secret_key

# Admin Seeding
# Comma-separated email:password pairs for seeded admin users.
# Passwords must be at least 8 characters long.
# These admins are created on startup if they don't already exist.
# Seeded admins cannot be demoted or deleted.
ADMIN_SEEDS=admin@example.com:changeme123
